      <documentation>(company) – Formally verified cryptographic libs. Hacspec (DSL) and libcrux.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-LIB-10 Liboqs" id="id-44133d8bd44d45b981d05371ef324407">
      <documentation>C-based API.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-LIB-11Oqsprovider" id="id-3ed3c9e4e26b403292ab528c1e926be5">
      <documentation>Extends OpenSSL3.</documentation>
    </element>
  </folder>
  <folder name="Technology &amp; Physical" id="id-5a19f96b800b494a8d2d4f619213909b" type="technology">
    <element xsi:type="archimate:SystemSoftware" name="Service Mesh (Sidecar / Gateway) " id="id-3db3a9ddfdd546a1a4310cc92ad027dd">
      <documentation>Enforces mTLS crypto suites and certificate profiles per policy; supports Hybrid Public Key Encryption (HPKE) based features where applicable.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Application Server" id="id-e9935b265c0848d894119635fc994bce">
      <documentation>Client/server stack (OpenSSL/BoringSSL/NSS/JDK) configured from the policy engine via IaC (CAVP/CMVP validations emerging for ML KEM/ML DSA in common modules). </documentation>
    </element>
    <element xsi:type="archimate:Node" name="Workload" id="id-250ec30f4a9f4bd094736fc43de11915">
      <documentation>Client/server stack (OpenSSL/BoringSSL/NSS/JDK) configured from the policy engine via IaC (CAVP/CMVP validations emerging for ML KEM/ML DSA in common modules).</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Secure Configuration Baseline (Artifact)" id="id-af8c0bb24fb0437995ebb414d9a43a00">
      <documentation>Versioned configs (Ansible/Terraform/Helm) for crypto suites, KEX, cert profiles, pinned algorithm OIDs.</documentation>
    </element>
    <element xsi:type="archimate:Equipment" name="P-EQP-1 HSM Appliance (On-Prem) " id="id-85a662ab66f340a592438b6b334403a2"/>
    <element xsi:type="archimate:Equipment" name="P-EQP-2 Smartcard/Hardware Token for Key Ceremony" id="id-e36f1490b12c4692849f90279feaf788"/>
    <element xsi:type="archimate:Facility" name="P-FAC-1 Data Center Key Custody Room / Safe" id="id-21f693777eaa409eb5009fbb7ad7558a"/>
    <element xsi:type="archimate:Material" name="P-MAT-1 Paper Backup / Sealed Envelope" id="id-f9afc0353e06408fbe174cfc6f568e69"/>
    <element xsi:type="archimate:Node" name="T-NOD-1 HSM" id="id-9302a58265604855837f7527a751b9cc">
      <documentation>FIPS 140 3 validated modules for secure key storage, PQC capable signature offload as vendors support ML DSA/SLH DSA. Aligns with SP 800 130/152 key protection. </documentation>
    </element>
    <element xsi:type="archimate:Node" name="T-NOD-2 KMS" id="id-181ea61d3a23478f82882b80bc419a53"/>
    <element xsi:type="archimate:Node" name="T-NOD-3 PKI/CA Server" id="id-568ab2607b3240bc8b50864b9a81bfe9"/>
    <element xsi:type="archimate:Node" name="T-NOD-4 Secrets Vault Node" id="id-adbd0243d13d460681646fe1dd206fcd"/>
    <element xsi:type="archimate:Node" name="T-NOD-5 API Gateway / TLS Terminator Node / Reverse Proxy" id="id-e7eda3a37c374acda7510beee625156f">
      <documentation>Terminates TLS 1.3; consumes policy for allowed suites and hybrid KEX (when supported).</documentation>
    </element>
    <element xsi:type="archimate:Node" name="T-NOD-6 Service Mesh Control Plane" id="id-1f6e36d4cae345cb9e7815636e9e4833"/>
    <element xsi:type="archimate:Node" name="T-NOD-7 Telemetry &amp; SIEM Platform" id="id-32bac024e88a4767ac8d27abf4b7bac9"/>
    <element xsi:type="archimate:SystemSoftware" name="T-SW-1 Crypto Providers (OpenSSL/BoringSSL/CNG/JCE)" id="id-cf7502eaf0ad4baa8988190bba76cbf9"/>
    <element xsi:type="archimate:SystemSoftware" name="T-SW-2 OS &amp; Container Runtime" id="id-7ab2e82079414022aab573ecb3724e88"/>
    <element xsi:type="archimate:TechnologyService" name="T-SRV-1 Secure Key Storage Service" id="id-728d324af07c4a72883f5fa8629ca95a"/>
    <element xsi:type="archimate:TechnologyService" name="T-SRV-2 Cryptographic Operations Service (Sign/Enc/KEM)" id="id-a09cd8b779b74ee7930e2e80de2cab07"/>
    <element xsi:type="archimate:TechnologyService" name="T-SRV-3 RNG / Entropy Service" id="id-50a83c98851d43f0a829a4d24d21fbc8"/>
    <element xsi:type="archimate:TechnologyService" name="T-SRV-4 Time Sync Service (NTP/PTP)" id="id-041761e157084be6b254033f3a6f318c">
      <documentation>Time sync to support PQC keygen/signing without bias; referenced in KMS designs. </documentation>
    </element>
    <element xsi:type="archimate:TechnologyService" name="T-SRV-5 Secure Transport Service (TLS/mTLS/IPsec)" id="id-b0c32802a81c4d55957e5f257f9e765b"/>
    <element xsi:type="archimate:TechnologyService" name="T-SRV-6 Logging &amp; Telemetry Ingestion" id="id-d2d718f041c54a5d8692761c8a8a27af"/>
    <element xsi:type="archimate:Artifact" name="T-ART-1 Approved Crypto Modules (FIPS-validated)" id="id-3f67915c150d4d13872503fcbe104067"/>
    <element xsi:type="archimate:Artifact" name="T-ART-2 HSM Key Store &amp; Partition" id="id-3187801c95d74586b8cd1aac1b5311b0"/>
    <element xsi:type="archimate:Artifact" name="T-ART-3 Trusted Root &amp; Intermediate CA Store" id="id-009da76256244fbd8c31431968a79b53"/>
  </folder>
  <folder name="Motivation" id="id-310a8d8634e34c06becc21ea8044ec51" type="motivation">
    <element xsi:type="archimate:Driver" name="M-DR-1 Quantum Threat to Cryptography" id="id-e7c5d88a5b39455bbf3fa5f9df47d56b">
      <documentation>Imminent risk that quantum-capable adversaries can break current public-key crypto (Harvest Now Decrypt Later, Trust Now Forge Later).</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="M-DR-2 Regulatory &amp; Customer Trust" id="id-ea84c37f11e14f518b26624cd8403cb5">
      <documentation>Legal, contractual, and market expectations (e.g., crypto strength, key management, auditability).</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="M-DR-3 Long-Term Data Confidentiality" id="id-08c1929d291946ccbb009e461a44cd08">
      <documentation>Sensitive data lifetimes exceed classical crypto safety windows.</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="M-DR-4 Long-Term Trust Associations" id="id-451108184dff4a8295c4c95a165dd814">
      <documentation>Certificate lifetimes exceed classical crypto safety windows.</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="M-GL-1 Crypto Agility Achieved " id="id-924ac16d7d724b2293d8ba84c28d863e">
      <documentation>Organization can identify and switch cryptography with minimal risk and lead-time.</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="M-GL-2 Quantum-Safe Posture" id="id-de0bb1dd02664a0694b774149ac0c42a">
      <documentation>PQC-ready protocols and controls with hybrid transitional support.</documentation>
    </element>
    <element xsi:type="archimate:Outcome" name="M-OC-1 Reduced Break/Replace Cost &amp; Time" id="id-1229011af7aa41f2ba6a1f3f616c09c6">
      <documentation>Material reduction in incident blast radius and migration timelines.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="M-RQ-1 Algorithm Independence" id="id-e2961fd6aad943969573bb890669b8c1">
      <documentation>Applications use policies/abstractions, not hard-coded algorithms.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="M-RQ-2 Complete Crypto Inventory " id="id-d6cbcbcc2f774a569920561577203c0c">
      <documentation>Transparent, continuously updated inventory of crypto usage (algorithms, keys, certs, libs, endpoints).</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="M-RQ-3 Automated Lifecycle " id="id-9114219473d2483aa9db48086d2b50e8">
      <documentation>Automated provisioning, rotation, renewal, and retirement of keys and certificates.</documentation>
    </element>
    <element xsi:type="archimate:Constraint" name="M-CS-1 Approved-Only Crypto" id="id-39888757e009493dbf521020af66a9e1">
      <documentation>Only organization-approved algorithms, modes, parameters, and modules.</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="M-PR-1 Secure-by-Default " id="id-295cc5962f224121874464f8dd26d381">
      <documentation>Defaults prefer strongest available crypto; downgrades require governance exceptions.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-1 Current Crypto Exposure " id="id-df81e7b2d9eb423992542d9af68adff6">
      <documentation>Baseline of vulnerable algorithms and endpoints.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-2 Harvest Now Decrypt Later" id="id-b34c1bd91f6440d3abdb671f6ebd2f60">
      <documentation>An adversary captures encrypted data today to decrypt it once a commercial CRQC is available.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-3 Trust Now Forge Later" id="id-54b4c92cd4b44f55911a7ed46020c0d2">
      <documentation>Malicious act of creating a fake digital signature to impersonate someone or manipulate data without authorization.&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-4 Malicious-signed software deployment" id="id-68464a73897f436aae4a533096cffc6d">
      <documentation>Installation of seamingly valid software signed by a digital signature counterfeit with a quantum computer.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-5 Remote attestation falsification" id="id-779bc9fdd87d4666b91359a7cac50a3b">
      <documentation>Spoofing a valid attestation response by exploiting quantum vulnerabilities, by altering transmission or computation on the attested system.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-6 Hybrid mode downgrade attack" id="id-700f988ffed1478e95d28071199c4ca4">
      <documentation>During the transition, endpoints support both classical and PQC algorithms. This attack exploits this quality.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-7 Man in the Middle (MITM)" id="id-37605f25c9b245b988046fbf8f17cc24">
      <documentation>A cyberattack where the attacker secretly relays and possibly alters the communication between two parties who believe they are genuinely communicating with each other, whereas the attacker has inserted themselves between the two.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-8 Data at rest attack" id="id-e4913d8bc5c54409a84ef024fb44a5b5">
      <documentation>Copying encrypted data from the device and decrypting it elsewhere or encrypting the data to make it unusable.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-AS-9 Data in transit attack" id="id-6024bbd1895e4d428d3533325a8d4c81">
      <documentation>Capturing network traffic and decrypting it (elsewhere).</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="M-PR-2 MemorySafe principle" id="id-319cc33056684fc0a3c0dfc87aa622f1"/>
    <element xsi:type="archimate:Principle" name="M-PR-3 Hybrid configuration" id="id-dccd42eab8e14e77928a94151027e313"/>
    <element xsi:type="archimate:Principle" name="M-PR-4 Backward Compatibility" id="id-5ed612098ec24d5db0c894b8c9b9afe3"/>
    <element xsi:type="archimate:Principle" name="M-PR-5 Shadow module architecture" id="id-8ba04c51344545f796d7d8dcc1bd2682">
      <documentation>Crypto ops are delegated to external libs rather than being implemented within the token itself. This promotes modularity, and simplifies updates.</documentation>
    </element>
  </folder>
