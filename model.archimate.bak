      <documentation>Delivers machine readable policies to gateways, service meshes, CDNs, servers, and client SDKs.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="A-SRV-2 Algorithm Selection &amp; Negotiation Service" id="id-46e644be4f4f4d14a73e80a7554547b3"/>
