    <element xsi:type="archimate:ApplicationService" name="A-SRV-6 Compliance Assessment &amp; Reporting Service" id="id-6b5afdcff0a742168f5d7f8fc9352fee"/>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-10 Crypto Compliance Engine" id="id-55531a40191f425cb48c801c123819b9"/>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-8 CBOM / Crypto Telemetry &amp; Inventory Collector" id="id-cc80b885bb2c43b8b16fd39ec8a7cfd3">
      <documentation>Enterprise datastore of Cryptography Bills of Materials (CBOM) for apps/services, using CycloneDX CBOM schema; joins SBOMs with crypto assets. </documentation>
    </element>
