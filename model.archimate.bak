<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="Crypto Agility" id="id-b26a0a64ac314319843668208a996e6e" version="5.0.0">
  <folder name="Strategy" id="id-52b3fa7e93934a9f96853d86fce26baa" type="strategy">
    <element xsi:type="archimate:Capability" name="ST-CAP-1 Cryptography Management Capability " id="id-5b437792e0a04a448293d390f4129b46">
      <documentation>Ability to govern, discover, select, implement, monitor and migrate cryptography.&#xD;
Note: Crypto Agility is the ability to replace/upgrade algorithms, parameters, and trust anchors without major redesigns or downtime (targets all layers). Guided by NIST’s Crypto Agility project. &#xD;
&#xD;
ST-CAP-1 is realized by Application &amp; Technology services later in the model.</documentation>
    </element>
    <element xsi:type="archimate:Resource" name="ST-RES-2 Crypto Risk Appetite" id="id-9a644fb4129f44b2b1bfaa72a02d07d9"/>
    <element xsi:type="archimate:Capability" name="ST-CAP-2 Secure DevSecOps Capability " id="id-b8b6374f02b44675a9955161e5aa03b7">
      <documentation>Integrates crypto policies, SBOM, code signing, SCA, and gate checks.</documentation>
    </element>
    <element xsi:type="archimate:Resource" name="ST-RES-1 Crypto Governance Playbook" id="id-683112ceba2c4b709c3575aea9f3c141">
      <documentation>Policies, standards, versioned patterns.&#xD;
An organization’s stance on algorithm baselines (min key sizes, approved suites), supported hybrids, and exception handling. Informed by SP 800 52r2 and CNSA 2.0. &#xD;
ST-RES-1 guides Application design-time and run-time selections.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-1 Inventory &amp; Classification" id="id-3d9e5873170a4b059e9aa4d0bbb3ddb2">
      <documentation>Identify all cryptographic assets and prioritize what needs PQC first.</documentation>
    </element>
    <element xsi:type="archimate:ValueStream" name="ST-VAL-1 Trust &amp; Compliance Value" id="id-6a04cd9eb7334b6289d0e8f7f0604633"/>
    <element xsi:type="archimate:Resource" name="ST-RES-3 PQC Migration Roadmap" id="id-d6338e1f0e004174b556e9290d2829da">
      <documentation>Incremental adoption via inventory, pilot hybrid, mass rollout, deprecations.&#xD;
Sequenced actions to prepare, discover, test, migrate, and monitor; aligns with CISA/NIST/NSA factsheet and NIST SP 1800 38.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-2 Dual-Stack / Hybrid Cryptography" id="id-1f1a638ad14a4ae9830f492ddc666c7d">
      <documentation>Combine classical and PQC algorithms simultaneously.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-3 Crypto Abstraction Layers" id="id-934f255c4ff3422dbe560ca6e7750afc">
      <documentation>Introduce indirection layers so algorithms can be swapped without redesign.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-4 Protocol Upgrades with Negotiation" id="id-84e66213e2794062b313ecf12712a31a">
      <documentation>Enable runtime negotiation of supported classical and PQC algorithms.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-5 Modular Key Management Upgrades" id="id-439ea38241c348d5856225d23d3ee6fc">
      <documentation>Ensure key generation, storage, and rotation support PQC formats.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-6 Algorithm Independent APIs" id="id-57896d240f4649b9a98735969a08b4f0">
      <documentation>Replace hard coded crypto calls with interfaces independent of algorithm choice.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-7 Incremental Component Replacement" id="id-b180ae69ad6a449ca133011038ce5819">
      <documentation>Swap cryptographic modules piece by piece without full system downtime.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-8 Fallback &amp; Rollback Mechanisms" id="id-c62fbb0c9e1344b1bfe37c353d6173b8">
      <documentation>Maintain the ability to revert or change algorithms quickly if issues occur.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-9 Testing with PQC Readiness Pipelines" id="id-a194f27462f44da5a30a01dfd6bffc32">
      <documentation>Integrate automated tests that validate algorithm agility and PQC support.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-10 Phased Deployment / Parallel Environments" id="id-2c9f125d4850485284a263523cc29ae9">
      <documentation>Run classical and PQC-enabled environments side by side before full cutover.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-11 Vendor &amp; Standards Alignment" id="id-0e03ac3be6bd42aa9485345e7c56fc70">
      <documentation>Ensure solutions track NIST PQC standards and external library support evolution.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-12 Continuous Monitoring for Cryptographic Drift" id="id-e6639f7ed2254df1b1707b79049bb0a5">
      <documentation>Detect and correct components that revert to legacy algorithms.&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-13 Pre-shared Symmetric Keys" id="id-14abdadc2ac7490aa6ecab0cbd99b6bd"/>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-14 Indirection Layer" id="id-b66c0b6e74a041938093450b26c4d92a">
      <documentation>Create an indirection layer: PKCS#11&#xD;
o	Use Qryptotoken, a modular, PKCS#11-based  loadable software token &#xD;
o	Use oqsprovider&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:Resource" name="ST-RES-ALG-1 RSA 2048" id="id-3acbf6c579eb448fa9bf58f0304aa735"/>
    <element xsi:type="archimate:Resource" name="ST-RES-ALG-2 ECDH" id="id-4cb5c8cc7a68438ca3ac3b0857d94b12"/>
    <element xsi:type="archimate:Resource" name="ST-RES-PTC-1 TLS 1.3" id="id-1d4812efb953426698ca21991320b0a7"/>
    <element xsi:type="archimate:Resource" name="ST-RES-PTC-2 IPSEC" id="id-d65f0b602ef547bbaf03a022ef16efdb"/>
    <element xsi:type="archimate:Resource" name="ST-RES-PTC-3 KMIP" id="id-bea3d1640d1c418fa9dcb2931312380c"/>
  </folder>
  <folder name="Business" id="id-51e7fd7c655c4897b747e6dc1931e1f8" type="business">
    <element xsi:type="archimate:BusinessRole" name="B-ROL-1 CISO / Crypto Owner" id="id-bd9e9293260347e8bf797116dbb20fb6">
      <documentation>Owns crypto posture, signs the roadmap, accepts risk. &#xD;
</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="B-OBJ-5 Crypto Posture Dashboard " id="id-25db2a2882234a789a41d8e8daf665fc">
      <documentation>KPI/KRI reporting: % TLS endpoints PQ ready, policy violations, cert expirations, HSM coverage, etc., surfaced from inventories and scanners.&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="B-OBJ-1 Crypto Policy" id="id-9755b2ea43584556b436814c96d049ed">
      <documentation>Enumerates minimums: TLS 1.3 only; allowed KEX (e.g., X25519+ML KEM 768 hybrids); signature algs (ML DSA for server certs when profiles stabilize); SHA 2/3 families; and sunsetting timelines for RSA/ECDSA where applicable. Align with SP 800 52r2, HPKE RFC, CNSA. </documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="B-ROL-2 Application Owner" id="id-db23eb92936c40c382cd3fe02e9ad6f2">
      <documentation>Consume policy and execute migrations on their services and client apps. </documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="B-ROL-3 PKI &amp; KMS Operations Team" id="id-e34a65d189814bf9bbc9fbefe3fcb2bd"/>
    <element xsi:type="archimate:BusinessRole" name="B-ROL-4 DevSecOps / Platform Team" id="id-d51653c03a7147a99a4ce64635477060"/>
    <element xsi:type="archimate:BusinessRole" name="B-ROL-5 Third-Party / Supplier " id="id-cd547ab099f4435fa49ef5244d6d580f"/>
    <element xsi:type="archimate:BusinessService" name="B-SRV-1 Crypto Governance Service" id="id-963b4f2417d24ae3b980e5e09e157ded"/>
    <element xsi:type="archimate:BusinessService" name="B-SRV-2 Crypto Risk &amp; Compliance Service" id="id-d490f1a56e0f487598efc9271fe029aa"/>
    <element xsi:type="archimate:BusinessService" name="B-SRV-4 Third-Party Crypto Assurance Service" id="id-f0b31282eb844991afe8299f4417fc09"/>
    <element xsi:type="archimate:BusinessProcess" name="B-PRC-1 Crypto Asset Management" id="id-8b7a00a4dfab435a884bee6a501d1867"/>
    <element xsi:type="archimate:BusinessProcess" name="B-PRC-2 Crypto Policy Management" id="id-3a23483e192546e5afcb15e1642d6be9"/>
    <element xsi:type="archimate:BusinessProcess" name="B-PRC-3 Exception Handling &amp; Waiver Management" id="id-3cd2a346874d4060a0fca99097e95502">
      <documentation>Waivers and temporary allowances for legacy systems, with time boxed compensating controls.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="B-PRC-4 Certificate Lifecycle Management" id="id-ceb1909ee3064544a2dd41b1d3b565fd"/>
    <element xsi:type="archimate:BusinessProcess" name="B-PRC-5 Key Lifecycle Management" id="id-d2f170032cd049ae94b5213fed057b10"/>
    <element xsi:type="archimate:BusinessProcess" name="B-PRC-6 Supplier/Third-Party Crypto Assurance" id="id-3104e70f3e3e4bb4a9888e09fd177cf1"/>
    <element xsi:type="archimate:BusinessService" name="B-SRV-5 Industry Standards Watch Service" id="id-197d77e09f06414b8ba7111ea668353b">
      <documentation>Systematic tracking of NIST PQC, IETF TLS/HPKE, ENISA EU guidance, etc., feeding updates to policy engine.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="B-OBJ-2 Crypto Risk Register" id="id-d89e5cf1657d4fe581f42380c78e78d6"/>
    <element xsi:type="archimate:BusinessObject" name="B-OBJ-3 Crypto Asset Inventory" id="id-a27df948b16546b1ae3ec10e0b24990f"/>
    <element xsi:type="archimate:BusinessObject" name="B-OBJ-4 Exception Register" id="id-e0205cc44deb467ea5f3ac6ad7a6403d"/>
    <element xsi:type="archimate:BusinessService" name="B-SRV-3 Application Crypto Onboarding Service" id="id-46bbcf94c2524fe4bf8ffb644d30802f"/>
    <element xsi:type="archimate:BusinessRole" name="B-ROL-6 Information Security Officer" id="id-9195baf2c52940f8bf66b6d77260b385"/>
    <element xsi:type="archimate:BusinessRole" name="B-ROL-7 InfoSec GRC Team" id="id-82e07b74c2cd47b5b579962e75121cae"/>
    <element xsi:type="archimate:BusinessRole" name="B-ROL-8 Crypto Expert" id="id-e1837bd6820c4f99b3f06745d69bf721"/>
  </folder>
  <folder name="Application" id="id-f62e927c03fc4207876166daf6671e8b" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-9 SBOM / SCA Scanner" id="id-d53e2e9129f24a6488df7d28886a7ca2"/>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-1 Crypto Policy Engine" id="id-94288c82144a4f84881311fb7f7b6ba0">
      <documentation>Centralized Crypto Policy Engine (TLS/SSH/IPsec).&#xD;
Authoritative source for allowed cipher suites, KEX (including hybrid), signature algorithms, parameters; exposes policy as APIs/OPA bundles for enforcement points. Aligns with SP 800 52r2 and CNSA profiles.&#xD;
Policy-first rollout honours design principle: versioned, testable, and reversible.&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="CBOM Ingestor/Generator" id="id-0348f6b07030401a98503dfb5892eef3">
      <documentation>Scans code, containers, and binaries; imports from CI/CD; normalizes to CBOM. Tooling patterns from CycloneDX and IBM CBOM. </documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Cryptographic Discovery Scanner " id="id-5eaccc314f224d3b9b500c924351949f">
      <documentation>Discovery of protocols, libraries, certs, key sizes in live estates (network/API scans, agent based). NIST SP 1800 38B provides functional test plans and a discovery architecture.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Crypto Posture Analyzer " id="id-d2255fe6a7fa4f61b89bdfc9ecd15981">
      <documentation>Evaluates CBOM + runtime scans vs. policy; emits violations, risk scores, and remediation plans. Leverages CISA/NIST quantum readiness guidance.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-5 Certificate Authority / PKI" id="id-59dfa78a90944158bd05633ce37e3bc7">
      <documentation>X.509 certificate issuing with PQC capable signature algorithms (e.g., ML DSA, SLH DSA) as standards and profiles mature (CNSA guidance for signing). </documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-14 PQC Interop Testbed / Canary Platform" id="id-c081d986bca34cd2b853c1e65c21c057">
      <documentation>Lab harness to test TLS 1.3 + hybrid KEX and HPKE (RFC 9180) use, plus perf/compat; echoes NIST SP 1800 38C.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Change Automation / CI CD Integrations " id="id-450d302cbd6542d7a3f307a6b0adacfa">
      <documentation>Gates builds on policy conformance, injects policy defaults into configs, generates CBOMs.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Remediation Playbooks Service " id="id-7311029b733f4012931c99b157f5c46c">
      <documentation>Curated steps per platform/library (OpenSSL/BoringSSL/NSS/JDK) to turn on ML KEM hybrids, switch signature algs, rotate keys, etc., referencing CNSA/NIST guidance.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Crypto Telemetry Lake " id="id-87f9c1f33f584d8c934bfdc0903df6a4">
      <documentation>Stores negotiation traces, JA3/JA4 like fingerprints, cert inventories, scanner results; feeds analytics and dashboards.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Crypto Telemetry Lake " id="id-cdbab349b32e493393242ea525b60ec4">
      <documentation>Negotiation traces, JA3/JA4 like fingerprints, certs, scanner results; analytics and dashboards.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Migration Runbook" id="id-ca5bd2a282994c9f93d85edd22e85aeb">
      <documentation>Sequenced steps by platform to roll out PQ/hybrid changes safely; referenced by playbooks service and SP 1800 38 guidance.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-2 Crypto Abstraction Library / SDK" id="id-3014676402f64954b14e8b47efd8b9e2">
      <documentation>Algorithm &amp; provider abstraction honours design principle: prevent hard coding; enable policy-driven selection.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-3 Key Management System (KMS)" id="id-1e1a2c1118754d6581667c5e20b45cc1">
      <documentation>Enterprise key lifecycle orchestration (Generate/Backup/Rotate/Retire), designed per NIST SP 800 130; applies SP 800 152 profile controls; integrates HSMs.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-4 Hardware Security Module Connector" id="id-a0f4fd2a809d4fcfbe82cad4906b38b9"/>
    <element xsi:type="archimate:ApplicationComponent" name="A-CMP-6 Certificate Management Orchestrator " id="id-735d1533f82a463ca34f324227eb6b25"/>
