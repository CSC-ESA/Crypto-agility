    <element xsi:type="archimate:Capability" name="ST-CAP Key Management Engineering" id="id-a0492a39d39942eb85c24ab85cbeff0b">
      <documentation>Ability to design, implement, and operate key lifecycle processes, HSM/KMS integrations, and hybrid key schemes.</documentation>
    </element>
