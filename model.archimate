    <element xsi:type="archimate:CourseOfAction" name="ST-COA Update PKI to PQC-Capable" id="id-705cd0baae0c48a19fc2a58653e2dca8"/>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA Define, Design and Implement Enterprise-Wide Cryptographic Agility" id="id-06d66759b99c4053b25ab46237ab1f5a">
      <documentation>Establish policies, design patterns, and automation pipelines enabling rapid algorithm substitution.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA Vendor &amp; Dependency Hardening" id="id-b7e7acf7274b417ba5cbb79256618838">
      <documentation>Assess and enforce PQC-readiness across suppliers, SaaS platforms, and embedded components.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA Migrate Cryptographic Protocols" id="id-01d579ce057a4d93947eb2ca1d037d3b">
      <documentation>Quantum-Resilient Key Management Overhaul: Redesign key lifecycle processes to support PQC algorithms, larger key sizes, and hybrid modes.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA Perform PQC Readiness Assessment" id="id-5f26b9fd3e0e4edaa513ec9d039ed118"/>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA Establish Cryptography Leadership Team / CoE" id="id-1f5cbfb52bb14302952a0879997d0db5"/>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA Define Migration Schedule" id="id-72d9b666c8734d689a9bc547d6d2d95b"/>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA PQC Migration Blueprinting" id="id-990a6b726475455d93ccd7f0bc0c1a21">
      <documentation>Define migration paths per asset class, including hybrid-PQC transition patterns and crypto-agility requirements.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="ST-CAP Cryptographic Asset Intelligence" id="id-71d84a2bb0604f9aa6d80658ee141632">
      <documentation>Cryptographic Discovery &amp; Analysis.&#xD;
Ability to maintain real-time visibility of all cryptographic usage, dependencies, and risks.&#xD;
Ability to scan, classify, and analyse cryptographic artefacts across systems, codebases, and infrastructure.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA Governance &amp; Assurance Loop" id="id-f2ab20c062aa40b0821ee853218bca13">
      <documentation>Implement continuous compliance monitoring, red-team crypto testing, and architecture guardrails.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="ST-CAP Architecture Modelling &amp; Roadmapping" id="id-5ce41b5ab3d0444cba161d5daba347b9">
      <documentation>Ability to design migration paths, hybrid patterns, and crypto-agile architectures.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="ST-CAP Secure Engineering &amp; DevSecOps Integration" id="id-a7e3654471a94ab794515e76959cb58c">
      <documentation>Ability to embed cryptographic policies, controls, and automation into CI/CD and development workflows.&#xD;
Integrates crypto policies, SBOM, code signing, SCA, and gate checks.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="ST-CAP Supplier Risk &amp; Dependency Management" id="id-b024b46c7eb347ada3c066dd1ad76f43">
      <documentation>Ability to assess, score, and enforce cryptographic requirements across vendors and third-party components.&#xD;
</documentation>
    </element>
