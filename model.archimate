  <folder name="Motivation" id="id-310a8d8634e34c06becc21ea8044ec51" type="motivation">
    <element xsi:type="archimate:Driver" name="M-DRV Regulatory and Policy Environment (NIS2)" id="id-ea84c37f11e14f518b26624cd8403cb5"/>
    <element xsi:type="archimate:Driver" name="M-DRV CRQC Threat to Long-Lived Data Confidentiality Obligations" id="id-08c1929d291946ccbb009e461a44cd08">
      <documentation>Sensitive data lifetimes exceed classical crypto safety windows.</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="M-DRV CRQC Threat to Long-Lived Trust Associations" id="id-451108184dff4a8295c4c95a165dd814">
      <documentation>Certificate lifetimes exceed classical crypto safety windows.</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="M-GOA Migrate all Cryptographic Assets at Risk to a Quantum-Safe State" id="id-924ac16d7d724b2293d8ba84c28d863e"/>
    <element xsi:type="archimate:Outcome" name="M-OUT Break/Replace Cost &amp; Time Reduced" id="id-1229011af7aa41f2ba6a1f3f616c09c6">
      <documentation>Material reduction in incident blast radius and migration timelines.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="M-REQ Cryptographic Choices Shall Be Externalized and Configurable" id="id-e2961fd6aad943969573bb890669b8c1"/>
    <element xsi:type="archimate:Requirement" name="M-REQ Cryptographic Algorithms Shall Be Replaceable Without System Redesign" id="id-9114219473d2483aa9db48086d2b50e8"/>
    <element xsi:type="archimate:Constraint" name="M-CTR Approved-Only Crypto" id="id-39888757e009493dbf521020af66a9e1">
      <documentation>Only organization-approved algorithms, modes, parameters, and modules.</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="M-PCP Security by Design" id="id-295cc5962f224121874464f8dd26d381">
      <documentation>Defaults prefer strongest available crypto; downgrades require governance exceptions.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Current Crypto Exposure " id="id-df81e7b2d9eb423992542d9af68adff6">
      <documentation>Baseline of vulnerable algorithms and endpoints.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Harvest Now Decrypt Later" id="id-b34c1bd91f6440d3abdb671f6ebd2f60">
      <documentation>An adversary captures encrypted data today to decrypt it once a commercial CRQC is available.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Trust Now Forge Later" id="id-54b4c92cd4b44f55911a7ed46020c0d2">
      <documentation>Malicious act of creating a fake digital signature to impersonate someone or manipulate data without authorization.&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Malicious-signed software deployment" id="id-68464a73897f436aae4a533096cffc6d">
      <documentation>Installation of seamingly valid software signed by a digital signature counterfeit with a quantum computer.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Remote attestation falsification" id="id-779bc9fdd87d4666b91359a7cac50a3b">
      <documentation>Spoofing a valid attestation response by exploiting quantum vulnerabilities, by altering transmission or computation on the attested system.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Hybrid mode downgrade attack" id="id-700f988ffed1478e95d28071199c4ca4">
      <documentation>During the transition, endpoints support both classical and PQC algorithms. This attack exploits this quality.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Man in the Middle (MITM)" id="id-37605f25c9b245b988046fbf8f17cc24">
      <documentation>A cyberattack where the attacker secretly relays and possibly alters the communication between two parties who believe they are genuinely communicating with each other, whereas the attacker has inserted themselves between the two.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Data at rest attack" id="id-e4913d8bc5c54409a84ef024fb44a5b5">
      <documentation>Copying encrypted data from the device and decrypting it elsewhere or encrypting the data to make it unusable.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="M-ASS Data in transit attack" id="id-6024bbd1895e4d428d3533325a8d4c81">
      <documentation>Capturing network traffic and decrypting it (elsewhere).</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="M-PCP Memory-Safety" id="id-319cc33056684fc0a3c0dfc87aa622f1"/>
    <element xsi:type="archimate:Principle" name="M-PCP Hybrid Configuration" id="id-dccd42eab8e14e77928a94151027e313"/>
    <element xsi:type="archimate:Principle" name="M-PCP Backward Compatibility" id="id-5ed612098ec24d5db0c894b8c9b9afe3"/>
    <element xsi:type="archimate:Principle" name="M-PCP Shadow Module Architecture" id="id-8ba04c51344545f796d7d8dcc1bd2682">
      <documentation>Crypto ops are delegated to external libs rather than being implemented within the token itself. This promotes modularity, and simplifies updates.&#xD;
The shadow module architecture principle (commonly known in software engineering as Shadow Testing or Shadowing) is a deployment strategy where a new version of a component or service—the &quot;shadow&quot;—runs alongside the existing production version (&quot;production&quot;) to process the same real-time traffic without affecting the final result seen by users.</documentation>
    </element>
    <element xsi:type="archimate:Value" name="M-VAL Continuity of Secure Operations" id="id-564f61dff5654c32ae8ac1f7456ea408"/>
    <element xsi:type="archimate:Value" name="M-VAL Future Proof Security Posture" id="id-a9472399842c4a29b2f46a7c38e4bad8">
      <documentation>Auditability &amp; Evidence Readiness.&#xD;
</documentation>
    </element>
