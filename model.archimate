  <folder name="Application" id="id-f62e927c03fc4207876166daf6671e8b" type="application">
    <folder name="PQC Module Implementations" id="id-07cb529de0614c46a9fed2cc125ecd75">
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-LIB Liboqs" id="id-44133d8bd44d45b981d05371ef324407">
        <documentation>C-based API.</documentation>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-LIB PQ Code Package" id="id-0b4447634ced426c88df677aab91fe85">
        <documentation>Supported: AWS-LC</documentation>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-LIB CIRCL (Cloudflare)" id="id-3c2f5c1ef9114244b7044b65b213cf9b"/>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-LIB SafeLogic CryptoComply PQ TLS" id="id-7628002385e04b6c940a39625bbb4456"/>
    </folder>
    <folder name="App Component Pool" id="id-af626dc3ac844dae86e971232c6d45d0">
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-2 Crypto Abstraction Library / SDK" id="id-3014676402f64954b14e8b47efd8b9e2">
        <documentation>Algorithm &amp; provider abstraction honours design principle: prevent hard coding; enable policy-driven selection.</documentation>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-3 Key Management System (KMS)" id="id-1e1a2c1118754d6581667c5e20b45cc1">
        <documentation>Enterprise key lifecycle orchestration (Generate/Backup/Rotate/Retire), designed per NIST SP 800 130; applies SP 800 152 profile controls; integrates HSMs.</documentation>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-4 Hardware Security Module Connector" id="id-a0f4fd2a809d4fcfbe82cad4906b38b9"/>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-5 Certificate Authority / PKI" id="id-59dfa78a90944158bd05633ce37e3bc7">
        <documentation>X.509 certificate issuing with PQC capable signature algorithms (e.g., ML DSA, SLH DSA) as standards and profiles mature (CNSA guidance for signing). </documentation>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-6 Certificate Management Orchestrator " id="id-735d1533f82a463ca34f324227eb6b25"/>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-7 Secrets Management (Vault) " id="id-6a634d50168d4152bafd6e7460ee31ea"/>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-8 CBOM / Crypto Telemetry &amp; Inventory Collector" id="id-cc80b885bb2c43b8b16fd39ec8a7cfd3">
        <documentation>Enterprise datastore of Cryptography Bills of Materials (CBOM) for apps/services, using CycloneDX CBOM schema; joins SBOMs with crypto assets. </documentation>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-9 SBOM / SCA Scanner" id="id-d53e2e9129f24a6488df7d28886a7ca2"/>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-10 Crypto Compliance Engine" id="id-55531a40191f425cb48c801c123819b9"/>
      <element xsi:type="archimate:ApplicationComponent" name="A-CMP-11 Code Signing Module" id="id-01e14d70fc864cada693097e7cf8f1e2"/>
