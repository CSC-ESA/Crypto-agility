<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="Crypto Agility" id="id-b26a0a64ac314319843668208a996e6e" version="5.0.0">
  <folder name="Strategy" id="id-52b3fa7e93934a9f96853d86fce26baa" type="strategy">
    <element xsi:type="archimate:Capability" name="ST-CAP Security Governance &amp; Assurance" id="id-5b437792e0a04a448293d390f4129b46">
      <documentation>•	Cryptographic Governance&#xD;
•	Security Policy Management&#xD;
•	Technology Portfolio Management&#xD;
•	Vendor Security Management&#xD;
•	Compliance Management&#xD;
&#xD;
Ability to define standards, monitor compliance, and run continuous cryptographic assurance activities.&#xD;
Ability to enforce standards, policies, and lifecycle controls across the organization.&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:Resource" name="ST-RES Crypto Risk Appetite" id="id-9a644fb4129f44b2b1bfaa72a02d07d9"/>
    <element xsi:type="archimate:Resource" name="ST-RES Crypto Governance Playbook" id="id-683112ceba2c4b709c3575aea9f3c141">
      <documentation>Policies, standards, versioned patterns.&#xD;
An organization’s stance on algorithm baselines (min key sizes, approved suites), supported hybrids, and exception handling. Informed by SP 800 52r2 and CNSA 2.0. &#xD;
Guides application design-time and run-time selections.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA Deploy Cryptographic Asset Inventory &amp; Classy Crypto Assets" id="id-3d9e5873170a4b059e9aa4d0bbb3ddb2">
      <documentation>&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:Resource" name="ST-RES PQC Migration Roadmap" id="id-d6338e1f0e004174b556e9290d2829da">
      <documentation>Incremental adoption via inventory, pilot hybrid, mass rollout, deprecations.&#xD;
Sequenced actions to prepare, discover, test, migrate, and monitor; aligns with CISA/NIST/NSA factsheet and NIST SP 1800 38.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA TCT Dual-Stack / Hybrid Cryptography" id="id-1f1a638ad14a4ae9830f492ddc666c7d">
      <documentation>Combine classical and PQC algorithms simultaneously.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Crypto Abstraction Layers" id="id-934f255c4ff3422dbe560ca6e7750afc">
      <documentation>Introduce indirection layers so algorithms can be swapped without redesign.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Protocol Upgrades with Negotiation" id="id-84e66213e2794062b313ecf12712a31a">
      <documentation>Enable runtime negotiation of supported classical and PQC algorithms.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Modular Key Management Upgrades" id="id-439ea38241c348d5856225d23d3ee6fc">
      <documentation>Ensure key generation, storage, and rotation support PQC formats.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Algorithm Independent APIs" id="id-57896d240f4649b9a98735969a08b4f0">
      <documentation>Replace hard coded crypto calls with interfaces independent of algorithm choice.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Incremental Component Replacement" id="id-b180ae69ad6a449ca133011038ce5819">
      <documentation>Swap cryptographic modules piece by piece without full system downtime.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Fallback &amp; Rollback Mechanisms" id="id-c62fbb0c9e1344b1bfe37c353d6173b8">
      <documentation>Maintain the ability to revert or change algorithms quickly if issues occur.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Testing with PQC Readiness Pipelines" id="id-a194f27462f44da5a30a01dfd6bffc32">
      <documentation>Integrate automated tests that validate algorithm agility and PQC support.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Phased Deployment / Parallel Environments" id="id-2c9f125d4850485284a263523cc29ae9">
      <documentation>Run classical and PQC-enabled environments side by side before full cutover.</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Continuous Monitoring for Cryptographic Drift" id="id-e6639f7ed2254df1b1707b79049bb0a5">
      <documentation>Detect and correct components that revert to legacy algorithms.&#xD;
</documentation>
    </element>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Pre-shared Symmetric Keys" id="id-14abdadc2ac7490aa6ecab0cbd99b6bd"/>
    <element xsi:type="archimate:CourseOfAction" name="ST-COA-TCT Indirection Layer" id="id-b66c0b6e74a041938093450b26c4d92a">
      <documentation>Create an indirection layer: PKCS#11&#xD;
o	Use Qryptotoken, a modular, PKCS#11-based  loadable software token &#xD;
o	Use oqsprovider&#xD;
</documentation>
    </element>
